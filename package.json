{
  "name": "tunneldesk",
  "version": "1.1.3",
  "private": true,
  "license": "GPL-3.0-only",
  "description": "SSH connection and port forwarding web console",
  "author": "zmide <zmide@users.noreply.github.com>",
  "homepage": "https://github.com/zmide/tunneldesk",
  "repository": {
    "type": "git",
    "url": "https://github.com/zmide/tunneldesk.git"
  },
  "main": "desktop/main.js",
  "scripts": {
    "build": "tsc",
    "desktop": "npm run build && electron .",
    "desktop:run": "electron .",
    "package": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "check:strict": "tsc -p tsconfig.strict.json",
    "regression": "npm run build && npm run check:strict && node scripts/check-frontend.js && node scripts/terminal-pty-check.js && node scripts/websocket-frame-check.js && node scripts/socks-forward-check.js && node scripts/auth-protection-check.js && node scripts/web-auth-integration-check.js && node scripts/log-reader-check.js && node scripts/database-transfer-check.js && node scripts/sftp-encoding-check.js && node scripts/fault-injection-check.js && node scripts/dependency-state-check.js && node scripts/desktop-startup-check.js && node scripts/sftp-pagination-check.js && node scripts/update-checker-check.js && node scripts/update-installer-check.js && node scripts/runtime-settings-check.js && node scripts/database-reopen-check.js && node scripts/database-credential-backup-check.js && node scripts/ssh2-error-isolation-check.js && node scripts/web-regression-harness.js",
    "ui:smoke": "npm run build && node scripts/ui-smoke-harness.js"
  },
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@pondwader/socks5-server": "^1.0.10",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "iconv-lite": "^0.7.3",
    "lucide": "^1.24.0",
    "ssh2": "^1.17.0"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "build": {
    "appId": "com.zmide.tunneldesk",
    "productName": "TunnelDesk",
    "npmRebuild": false,
    "buildDependenciesFromSource": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "desktop/**/*",
      "dist/**/*",
      "public/**/*",
      "package.json"
    ],
    "extraResources": [
      "LICENSE"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "afterPack": "scripts/after-pack.js",
    "win": {
      "icon": "desktop/assets/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "${productName}-${version}-windows-${arch}-installer.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-windows-${arch}-portable.${ext}"
    },
    "linux": {
      "artifactName": "${productName}-${version}-linux-${arch}.${ext}",
      "icon": "desktop/assets/icon.png",
      "maintainer": "zmide <zmide@users.noreply.github.com>",
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ]
    },
    "mac": {
      "artifactName": "${productName}-${version}-macos-${arch}.${ext}",
      "icon": "desktop/assets/icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
